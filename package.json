{
  "name": "status-page-to-chat",
  "version": "1.0.0",
  "description": "Ueberwacht Status-Pages externer Anbieter und postet Stoerungen in Google Chat oder Teams",
  "main": "dist/src/functions/poll.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ && prettier --check src/ tests/",
    "format": "prettier --write src/ tests/",
    "start": "func start"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure/data-tables": "^13.2.2",
    "@azure/functions": "^4.5.1",
    "pino": "^9.6.0",
    "undici": "^7.3.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  },
  "private": true,
  "license": "MIT"
}
